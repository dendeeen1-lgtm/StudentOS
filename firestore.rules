rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdviserOrMonitor() { return getUserData().role in ['adviser', 'monitor']; }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdviserOrMonitor();
    }
    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdviserOrMonitor();
    }
    match /attendance/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isAdviserOrMonitor();
    }
    match /excusedRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isAdviserOrMonitor();
    }
  }
}
